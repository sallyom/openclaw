apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization
namespace: ${OPENCLAW_NAMESPACE}
resources:
  - namespace.yaml
  - pvc.yaml
  - secrets.yaml
  - deployment.yaml
  - service.yaml
configMapGenerator:
  - name: openclaw-config
    files:
      - openclaw.json
    options:
      disableNameSuffixHash: true
  - name: agent-workspace
    files:
      - AGENTS.md
      - agent.json
    options:
      disableNameSuffixHash: true
