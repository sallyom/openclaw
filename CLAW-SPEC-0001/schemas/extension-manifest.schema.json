{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claw.dev/specs/extension-manifest.schema.json",
  "title": "Claw Extension Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["kind", "id", "version", "extensionKind", "compatibility"],
  "properties": {
    "kind": {
      "const": "claw.extension"
    },
    "specVersion": {
      "type": "string",
      "default": "claw.extension.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "extensionKind": {
      "type": "string",
      "enum": ["channel", "tool", "provider", "setup", "policy", "observability", "bridge", "other"]
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["specs"],
      "properties": {
        "hosts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "specs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "entrypoints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runtime": {
          "type": "string"
        },
        "setup": {
          "type": "string"
        },
        "rpc": {
          "type": "string"
        }
      }
    },
    "configSchemaRef": {
      "type": "string"
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "channel": {
      "$ref": "#/$defs/channelMeta"
    },
    "distribution": {
      "$ref": "#/$defs/distribution"
    },
    "metadata": {
      "type": "object"
    }
  },
  "$defs": {
    "channelMeta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "selectionLabel": {
          "type": "string"
        },
        "docsPath": {
          "type": "string"
        },
        "blurb": {
          "type": "string"
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "distribution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "npm": {
          "type": "string"
        },
        "oci": {
          "type": "string"
        },
        "git": {
          "type": "string",
          "format": "uri"
        },
        "localPath": {
          "type": "string"
        }
      }
    }
  }
}
