{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claw.dev/specs/skill-package.schema.json",
  "title": "Claw Skill Interop Manifest",
  "type": "object",
  "additionalProperties": true,
  "description": "Additive interop metadata for an AgentSkills-style skill package. This does not replace SKILL.md or the AgentSkills layout.",
  "required": ["kind", "name", "version", "description", "skillEntry"],
  "properties": {
    "kind": {
      "const": "claw.skill"
    },
    "specVersion": {
      "type": "string",
      "default": "claw.skill.v1"
    },
    "baseSkillFormat": {
      "type": "string",
      "default": "agentskills.v1",
      "description": "The underlying portable skill format. Claw hosts should prefer raw AgentSkills packages when possible."
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "license": {
      "type": "string"
    },
    "skillEntry": {
      "type": "string",
      "description": "Path to the canonical skill entry file, typically SKILL.md"
    },
    "assets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/asset"
      }
    },
    "compatibility": {
      "$ref": "#/$defs/compatibility"
    },
    "requirements": {
      "$ref": "#/$defs/requirements"
    },
    "commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/command"
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tool"
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "$defs": {
    "compatibility": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "hosts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "specs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bins": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "env": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "config": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "os": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["darwin", "linux", "win32"]
          }
        }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string"
        },
        "mediaType": {
          "type": "string"
        },
        "optional": {
          "type": "boolean"
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "dispatch": {
          "type": "string",
          "enum": ["model", "tool"]
        },
        "toolName": {
          "type": "string"
        }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "inputSchema": {
          "type": "object"
        }
      }
    }
  }
}
